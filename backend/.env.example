# ============================================
# OPEN SOURCE CONTRIBUTION ATELIER
# Environment Configuration
# ============================================

# ============ APPLICATION SETTINGS ============
# Set DEBUG=False for production
DEBUG=False

# Production secret key (use: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-generated-secure-key-here

# Comma-separated list
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app

# ============ DATABASE ============
# Primary Database (PostgreSQL)
DATABASE_URL=postgresql://contribution_atelier:secure_password_here@localhost:5432/contribution_atelier

# Legacy Database (SQLite - for dev only)
DB_NAME=contribution_atelier
DB_USER=contribution_atelier
DB_PASSWORD=secure_password_here
DB_HOST=localhost
DB_PORT=5432

# ============ REDIS ============
REDIS_URL=redis://localhost:6379/0

# ============ AUTHENTICATION ============
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ACCESS_TOKEN_LIFETIME=15
JWT_REFRESH_TOKEN_LIFETIME=7

# ============ GITHUB OAUTH ============
# Get from GitHub OAuth Apps: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# ============ GITHUB APP ============
# Get from GitHub Apps: https://github.com/settings/apps
GITHUB_APP_ID=your_actual_app_id
GITHUB_INSTALLATION_ID=your_actual_installation_id
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# ============ CORS & FRONTEND ============
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# ============ EMAIL ============
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ============ VAPID (Web Push) ============
# Generate: https://web-push-codelab.glitch.me/
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_ADMIN_EMAIL=mailto:admin@yourdomain.com

# ============ AWS S3 (Backups) ============
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BACKUP_BUCKET=your-backup-bucket-name

# ============ NOTIFICATIONS ============
# Web Push
WEB_PUSH_PRIVATE_KEY=your_web_push_private_key
WEB_PUSH_PUBLIC_KEY=your_web_push_public_key

# ============ API KEYS ============
# Add any other API keys herecket
BACKUP_RETENTION_DAYS=30
